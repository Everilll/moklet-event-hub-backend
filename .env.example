# ==============================
# App
# ==============================
NODE_ENV=development
PORT=3000

# ==============================
# Database (Prisma 7.8.0 + @prisma/adapter-pg)
# ==============================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/moklet_event_hub?schema=public"

# ==============================
# JWT
# ==============================
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ==============================
# Google OAuth (login Gmail institusi)
# ==============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Domain Gmail institusi yang diizinkan login (dipakai buat validasi domain di auth.service)
GOOGLE_ALLOWED_HD=student.smktelkom-mlg.sch.id

# ==============================
# OTP
# ==============================
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_REQUESTS_PER_WINDOW=3
OTP_WINDOW_SECONDS=600

# ==============================
# Throttler (rate limiting global, dipakai juga oleh OTP endpoint)
# ==============================
THROTTLE_TTL=60
THROTTLE_LIMIT=20

# ==============================
# SMTP (pengiriman kode OTP via email)
# ==============================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Moklet Event Hub <no-reply@smktelkom-mlg.sch.id>"

# ==============================
# CORS
# ==============================
FRONTEND_URL=http://localhost:5173
