// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SISWA
  PANITIA
  ADMIN_KESISWAAN
}

enum EventStatus {
  ONGOING
  CLOSED
}

enum TeamStatus {
  OPEN
  LOCKED
  FULL
  DISQUALIFIED
}

enum TeamCompositionMode {
  FREE
  PER_CLASS
  PER_ANGKATAN
}

model SystemSetting {
  id                  String   @id @default(uuid()) @db.Uuid
  currentTopAngkatan  Int
  currentAcademicYear String   // 2026/2027
  updatedAt           DateTime @updatedAt
}

model Class {
  id       String    @id @default(uuid()) @db.Uuid
  grade    String
  name     String
  students Student[]

  @@unique([grade, name])
}

model Student {
  id                    String                 @id @default(uuid()) @db.Uuid
  name                  String
  nis                   String?                @unique
  classId               String                 @db.Uuid
  class                 Class                  @relation(fields: [classId], references: [id], onDelete: Restrict)
  angkatan              Int?
  photoUrl              String?
  photoPublicId         String?
  deletedAt             DateTime?
  account               Account?
  teamMembers           TeamMember[]
  registrations         Registration[]
  eventCommitteeMembers EventCommitteeMember[]
}

model Account {
  id                    String                 @id @default(uuid()) @db.Uuid
  email                 String                 @unique
  passwordHash          String?
  role                  Role                   @default(SISWA)
  isVerified            Boolean                @default(false)
  studentId             String?                @unique @db.Uuid
  student               Student?               @relation(fields: [studentId], references: [id], onDelete: SetNull)
  events                Event[]
  announcements         Announcement[]
  exportLogs            ExportLog[]
  otpHash               String?
  otpExpiresAt          DateTime?
  eventCommitteeMembers EventCommitteeMember[]
}

model Event {
  id                    String                 @id @default(uuid()) @db.Uuid
  name                  String
  description           String?
  bannerUrl             String?
  bannerPublicId        String?
  guidebookUrl          String?
  guidebookPublicId     String?
  status                EventStatus            @default(ONGOING)
  eventDate             DateTime
  createdById           String                 @db.Uuid
  createdBy             Account                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  categories            Category[]
  eventSchedules        EventSchedule[]
  eventCommitteeMembers EventCommitteeMember[]
  announcements         Announcement[]
  exportLogs            ExportLog[]

  @@index([status])
}

model EventCommitteeMember {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @db.Uuid
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId String   @db.Uuid
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  addedById String   @db.Uuid
  addedBy   Account  @relation(fields: [addedById], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())

  @@unique([eventId, studentId])
}

model EventSchedule {
  id                     String   @id @default(uuid()) @db.Uuid
  eventId                String   @db.Uuid
  event                  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date                   DateTime @db.Date
  dayLabel               String
  dresscodeText          String
  dresscodeImageUrl      String?
  dresscodeImagePublicId String?

  @@unique([eventId, date])
}

model Category {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  minMember           Int                  @default(1)
  maxMember           Int                  @default(1)
  teamCompositionMode TeamCompositionMode  @default(FREE)
  maxTeamsPerGroup    Int?
  maxTotalTeams       Int?
  excludeGrade12      Boolean              @default(true)
  eventId             String               @db.Uuid
  event               Event                @relation(fields: [eventId], references: [id], onDelete: Restrict)
  teams               Team[]
  registrations       Registration[]
  exportLogs          ExportLog[]
}

model Team {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  code           String         @unique
  status         TeamStatus     @default(OPEN)
  groupKey       String?
  quotaConfirmed Boolean        @default(false)
  categoryId     String         @db.Uuid
  category       Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  teamMembers    TeamMember[]
  registrations  Registration[]

  @@index([categoryId])
  @@index([categoryId, groupKey])
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @db.Uuid
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  studentId String   @db.Uuid
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  isLeader  Boolean  @default(false)
  joinedAt  DateTime @default(now())

  @@unique([teamId, studentId])
}

model Registration {
  id         String   @id @default(uuid()) @db.Uuid
  studentId  String   @db.Uuid
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  categoryId String   @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  teamId     String?  @db.Uuid
  team       Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@unique([studentId, categoryId])
}

model Announcement {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  content     String
  eventId     String?  @db.Uuid
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdById String   @db.Uuid
  createdBy   Account  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([eventId])
}

model ExportLog {
  id           String    @id @default(uuid()) @db.Uuid
  categoryId   String?   @db.Uuid
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  eventId      String?   @db.Uuid
  event        Event?    @relation(fields: [eventId], references: [id], onDelete: Restrict)
  exportedById String    @db.Uuid
  exportedBy   Account   @relation(fields: [exportedById], references: [id], onDelete: Restrict)
  createdAt    DateTime  @default(now())
}
